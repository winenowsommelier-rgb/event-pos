{
  "functions": {
    "api/process.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/process", "dest": "/api/process.js" },
    { "src": "/pdf-tool", "dest": "/pdf_tool.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
